<div class="card">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h2">案件一覧</h1>
      <%= link_to "カレンダー表示に戻る", events_path, class: "btn btn-outline-secondary" %>
    </div>

    <%# 検索フォーム %>
    <div class="bg-light p-3 rounded mb-4 border">
      <%= search_form_for @q, url: list_events_path, method: :get do |f| %>
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <%= f.label :title_cont, "案件名", class: "form-label" %>
            <%= f.search_field :title_cont, class: "form-control" %>
          </div>
          <div class="col-md-3">
            <%= f.label :status_eq, "ステータス", class: "form-label" %>
            <%= f.select :status_eq, Event.statuses.keys.map { |k| [t("activerecord.attributes.event.statuses.#{k}"), k] }, { include_blank: 'すべて' }, { class: "form-select" } %>
          </div>
          <div class="col-md-3">
            <%= f.label :start_time_gteq, "開始日", class: "form-label" %>
            <%= f.date_field :start_time_gteq, class: "form-control" %>
          </div>
          <div class="col-md-2">
            <div class="d-grid gap-2 d-md-flex">
              <%= f.submit "検索", class: "btn btn-primary" %>
              <%= link_to "クリア", list_events_path, class: "btn btn-secondary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# 検索結果一覧 %>
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead>
          <tr>
            <th>案件名</th>
            <th>担当者</th>
            <th>開始日時</th>
            <th>終了日時</th>
            <th>ステータス</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @events.each do |event| %>
            <tr>
              <td><%= event.title %></td>
              <td><%= event.user.email %></td>
              <td><%= l event.start_time, format: :long %></td>
              <td><%= l event.end_time, format: :long %></td>
              <td><span class="badge bg-secondary"><%= t("activerecord.attributes.event.statuses.#{event.status}") %></span></td>
              <td>
                <%= link_to '詳細', edit_event_path(event), data: { turbo_frame: "modal" }, class: "btn btn-sm btn-outline-primary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
